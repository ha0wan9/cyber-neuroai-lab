{
  "slug": "08-brain-signals-fmri",
  "title": "Brain Signals: fMRI",
  "source_page": "https://compneuro.neuromatch.io/tutorials/W0D0_NeuroVideoSeries/student/W0D0_Tutorial8.html",
  "youtube_url": "https://youtube.com/watch?v=8hhQGHYsXOY",
  "summary_language": "zh",
  "summaries": [
    {
      "index": 1,
      "timestamp": "00:00:00.160 - 00:00:18.000",
      "summary": "Pedro Valdez-Sosa 介绍自己来自电子科技大学古巴-中国联合实验室及古巴神经科学中心，将简要介绍 fMRI。"
    },
    {
      "index": 2,
      "timestamp": "00:00:20.560 - 00:00:59.680",
      "summary": "1990 年 Ogawa 首次发现 BOLD 效应，并利用该信号发表了人类视觉皮层功能图像。"
    },
    {
      "index": 3,
      "timestamp": "00:01:01.280 - 00:01:16.000",
      "summary": "本讲只聚焦最普遍的 BOLD 信号，自 1990 年首篇人类研究后。"
    },
    {
      "index": 4,
      "timestamp": "00:01:18.000 - 00:01:36.000",
      "summary": "随后几个月出现多种技术变体的 BOLD 图像，导致 fMRI 方法和实验的爆发。"
    },
    {
      "index": 5,
      "timestamp": "00:01:36.000 - 00:02:14.480",
      "summary": "fMRI 流行原因在于能在活体中观层面研究大脑动力学，并具有空间和时间分辨率。"
    },
    {
      "index": 6,
      "timestamp": "00:02:16.000 - 00:02:27.680",
      "summary": "空间分辨率指大脑中两个活动点能被区分的最小距离，时间分辨率指时间上的接近程度，分辨率越高细节越清晰。"
    },
    {
      "index": 7,
      "timestamp": "00:02:27.680 - 00:03:03.680",
      "summary": "在空间/时间分辨率及侵入性图表中，fMRI 虽不如 MEG/EEG 快，但空间分辨率更高，可分辨到皮层柱层。"
    },
    {
      "index": 8,
      "timestamp": "00:03:03.680 - 00:03:13.040",
      "summary": "接下来将解释如何测量 fMRI。"
    },
    {
      "index": 9,
      "timestamp": "00:03:14.000 - 00:03:35.760",
      "summary": "fMRI 在 MRI 机器中测量，将介绍其测量内容、实验类型及参考文献。"
    },
    {
      "index": 10,
      "timestamp": "00:03:35.760 - 00:04:10.800",
      "summary": "MRI 机器是巨大磁铁，如古巴神经科学中心的 3 特斯拉系统，磁铁强度约 60,000。"
    },
    {
      "index": 11,
      "timestamp": "00:04:10.800 - 00:04:35.400",
      "summary": "强磁场比地球磁场强数倍，对齐自旋的氢核，通过梯度位移后返回时发射射频，分析得到空间定位的活动。"
    },
    {
      "index": 12,
      "timestamp": "00:04:35.400 - 00:05:13.360",
      "summary": "MRI主要分为结构MRI（高质量结构图像）和功能MRI（基于血氧变化），两者通过不同的序列实现。"
    },
    {
      "index": 13,
      "timestamp": "00:05:13.360 - 00:05:51.720",
      "summary": "通过调整梯度和射频的发射与接收可以生成多种MRI序列，结构MRI单次成像需4-6分钟，分辨率极高（如1毫米）。"
    },
    {
      "index": 14,
      "timestamp": "00:05:51.720 - 00:06:22.080",
      "summary": "功能MRI是动态时间序列，每帧通常在3秒以内（特殊情况下可至100毫秒），分辨率较低，序列优化用于检测血氧水平等功能特征。"
    },
    {
      "index": 15,
      "timestamp": "00:06:22.960 - 00:07:00.320",
      "summary": "序列图像组装成统计图像；典型实验中受试者观看屏幕或听声音并做出反应。"
    },
    {
      "index": 16,
      "timestamp": "00:07:00.880 - 00:07:09.760",
      "summary": "受试者可以听不同声音并做出响应。"
    },
    {
      "index": 17,
      "timestamp": "00:07:11.680 - 00:07:33.920",
      "summary": "典型实验通过指令受试者睁眼闭眼并记录图像对比，显示视觉皮层及视觉相关区域的激活。"
    },
    {
      "index": 18,
      "timestamp": "00:07:34.800 - 00:07:38.160",
      "summary": "该实验也在古巴中心进行过。"
    },
    {
      "index": 19,
      "timestamp": "00:07:39.680 - 00:07:54.800",
      "summary": "fMRI测量的是血氧水平依赖（BOLD）信号。"
    },
    {
      "index": 20,
      "timestamp": "00:07:56.000 - 00:08:31.360",
      "summary": "神经元无内部能量储备，活动时快速供能导致血氧过剩，称为血氧动力学响应（hemodynamic response）。"
    },
    {
      "index": 21,
      "timestamp": "00:08:32.000 - 00:09:15.280",
      "summary": "去氧血红蛋白引起磁场扭曲，降低MRI信号强度。"
    },
    {
      "index": 22,
      "timestamp": "00:09:16.080 - 00:09:56.080",
      "summary": "激活时氧合血细胞涌入，氧合血红蛋白不扭曲磁场，使MRI信号增强。"
    },
    {
      "index": 23,
      "timestamp": "00:09:56.080 - 00:10:07.277",
      "summary": "氧合血红蛋白不扭曲磁场，导致MRI信号增加。"
    },
    {
      "index": 24,
      "timestamp": "00:10:07.277 - 00:10:42.160",
      "summary": "突触活动（spike释放神经递质）通过星形胶质细胞引起小动脉扩张和血流量增加。"
    },
    {
      "index": 25,
      "timestamp": "00:10:43.040 - 00:11:24.720",
      "summary": "血容量增加与去氧血红蛋白减少共同产生BOLD响应，比较未激活和激活状态可识别神经活动增强区域。"
    },
    {
      "index": 26,
      "timestamp": "00:11:24.720 - 00:12:02.360",
      "summary": "MRI信号在神经激活后数秒达峰，经历初始下降后回升，此血液动力学响应是fMRI的基础。"
    },
    {
      "index": 27,
      "timestamp": "00:12:02.360 - 00:12:29.520",
      "summary": "实验类型取决于刺激呈现与统计分析，主要介绍block设计和event-related设计两种。"
    },
    {
      "index": 28,
      "timestamp": "00:12:31.200 - 00:13:15.200",
      "summary": "Block设计通过统计比较不同条件（如睁眼闭眼）的BOLD效应，得到显著活动变化的脑区。"
    },
    {
      "index": 29,
      "timestamp": "00:13:15.840 - 00:13:50.880",
      "summary": "Event-related设计比较不同刺激，例如Navon图形（大形状由小形状组成，如字母或方块）。"
    },
    {
      "index": 30,
      "timestamp": "00:13:51.520 - 00:14:31.200",
      "summary": "通过Navon图形让被试注意整体或局部形状，可分离出不同类型注意处理的脑效应。"
    },
    {
      "index": 31,
      "timestamp": "00:14:31.200 - 00:14:45.760",
      "summary": "该设计通过统计比较不同刺激周围的活动来区分条件，比block设计更精细且服务于不同目的。"
    },
    {
      "index": 32,
      "timestamp": "00:14:45.760 - 00:15:25.417",
      "summary": "静息态fMRI让被试在扫描仪中休息并测量无外部刺激时的脑活动，被称为心智游移或内部心理过程。"
    },
    {
      "index": 33,
      "timestamp": "00:15:25.417 - 00:16:04.520",
      "summary": "Bharat Biswal于1994年发现不同脑区间的活动相关性可揭示跨脑的广泛功能连接网络，该网络与不同条件和实验相关。"
    },
    {
      "index": 34,
      "timestamp": "00:16:04.520 - 00:16:26.640",
      "summary": "介绍了block、event-related和resting-state三种基本fMRI范式，并提供了进一步阅读的参考文献，包括建模相关书籍。"
    }
  ]
}