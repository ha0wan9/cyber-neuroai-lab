{
  "slug": "05-brain-signals-spiking-activity",
  "title": "Brain Signals: Spiking Activity",
  "source_page": "https://compneuro.neuromatch.io/tutorials/W0D0_NeuroVideoSeries/student/W0D0_Tutorial5.html",
  "youtube_url": "https://youtube.com/watch?v=1nhioy3f9BY",
  "summary_language": "zh",
  "summaries": [
    {
      "index": 1,
      "timestamp": "00:00:00.880 - 00:00:29.040",
      "summary": "介绍神经元作为神经系统基本单元，其特性允许产生动作电位。"
    },
    {
      "index": 2,
      "timestamp": "00:00:29.600 - 00:00:59.840",
      "summary": "概述将讨论动作电位过程、记录方法、spike在神经通信中的价值以及其优缺点。"
    },
    {
      "index": 3,
      "timestamp": "00:01:00.960 - 00:01:33.360",
      "summary": "神经元通过电信号通信，介绍树突收集信号、胞体（soma）整合信号。"
    },
    {
      "index": 4,
      "timestamp": "00:01:33.920 - 00:02:05.360",
      "summary": "胞体整合信号触发动作电位，经轴丘沿轴突传至轴突末梢突触释放神经递质。"
    },
    {
      "index": 5,
      "timestamp": "00:02:05.360 - 00:02:22.080",
      "summary": "介绍分级电位（graded potentials）是不同强度的电信号。"
    },
    {
      "index": 6,
      "timestamp": "00:02:22.640 - 00:02:42.240",
      "summary": "树突将加权电位求和，若超过阈值则触发动作电位。"
    },
    {
      "index": 7,
      "timestamp": "00:02:43.920 - 00:03:19.040",
      "summary": "动作电位（spike）是膜电位的快速极性变化，细胞膜内外离子分布不同。"
    },
    {
      "index": 8,
      "timestamp": "00:03:19.040 - 00:03:57.840",
      "summary": "细胞内外离子分布差异形成梯度，静息电位约-70 mV，细胞外正电荷多于内部。"
    },
    {
      "index": 9,
      "timestamp": "00:03:58.800 - 00:04:29.200",
      "summary": "膜上有选择性离子通道，细胞外主要Na+、内主要K+，动作电位起始为Na+内流使内部正电荷增加。"
    },
    {
      "index": 10,
      "timestamp": "00:04:29.200 - 00:04:58.000",
      "summary": "紧接着K+外流带出正电荷，使细胞内部重新变得相对负。"
    },
    {
      "index": 11,
      "timestamp": "00:04:58.000 - 00:05:21.760",
      "summary": "绘制时间-振幅图，说明分级电位中膜电位从静息-70 mV开始变化。"
    },
    {
      "index": 12,
      "timestamp": "00:05:22.320 - 00:05:42.160",
      "summary": "分级电位超过-55 mV阈值才会触发动作电位，这是临界点。"
    },
    {
      "index": 13,
      "timestamp": "00:05:43.520 - 00:06:17.600",
      "summary": "动作电位是“全或无”的：超过阈值后总是先升至约+30 mV再回落，过程固定。"
    },
    {
      "index": 14,
      "timestamp": "00:06:17.600 - 00:06:47.040",
      "summary": "多个刺激叠加达到阈值引发Na+内流和K+外流，产生超射后恢复静息电位。"
    },
    {
      "index": 15,
      "timestamp": "00:06:47.040 - 00:07:19.280",
      "summary": "用冲厕所类比：用力不足不会完全冲水，只有达到阈值才能引发完整、刻板的反应。"
    },
    {
      "index": 16,
      "timestamp": "00:07:19.280 - 00:07:42.000",
      "summary": "一旦超过阈值，后续反应序列固定，且动作电位具有不应期，类似冲厕所的间隔限制。"
    },
    {
      "index": 17,
      "timestamp": "00:07:42.640 - 00:08:10.560",
      "summary": "不应期使相邻动作电位之间存在最小时间延迟，限制了每秒最大频率，对应手指运动速度上限。"
    },
    {
      "index": 18,
      "timestamp": "00:08:11.840 - 00:08:44.080",
      "summary": "记录神经元的spike时，电信号非常微小，需要使用导电金属或玻璃微电极。"
    },
    {
      "index": 19,
      "timestamp": "00:08:44.080 - 00:08:58.720",
      "summary": "电极可以是金属或充满液体的玻璃微吸管，内部含有导电金属。"
    },
    {
      "index": 20,
      "timestamp": "00:08:59.360 - 00:09:11.440",
      "summary": "微小信号需经放大、数字化，再通过采集单元整合与解释。"
    },
    {
      "index": 21,
      "timestamp": "00:09:12.400 - 00:09:49.120",
      "summary": "所记录的动作电位来自单个神经元，信息编码于其发放频率和模式中，与具有不同强度和时程的 graded potential 不同。"
    },
    {
      "index": 22,
      "timestamp": "00:09:49.120 - 00:10:08.320",
      "summary": "动作电位强度固定（-70到+30 mV）、时程固定（2-4毫秒），信息通过其发放模式和频率编码，需要整理数据以理解。"
    },
    {
      "index": 23,
      "timestamp": "00:10:09.440 - 00:10:44.320",
      "summary": "动作电位需达到阈值，电压门控通道允许钠离子内流和钾离子外流，这些特性共同帮助我们理解 spike。"
    },
    {
      "index": 24,
      "timestamp": "00:10:45.120 - 00:11:02.320",
      "summary": "spike 产生前必须达到阈值，神经元有最大发放频率，且涉及钠钾离子通道。"
    },
    {
      "index": 25,
      "timestamp": "00:11:03.040 - 00:11:29.840",
      "summary": "还存在 leaky channels，持续允许少量正离子流入细胞，随时间累积可能触发动作电位。"
    },
    {
      "index": 26,
      "timestamp": "00:11:29.840 - 00:11:43.600",
      "summary": "以图表为例，展示 leaky channels 如何导致膜电位缓慢去极化直至阈值并触发 spike。"
    },
    {
      "index": 27,
      "timestamp": "00:11:44.800 - 00:12:25.520",
      "summary": "在时间（ms）-振幅（mV）图中，从-70 mV起始，漏通道使膜电位缓慢去极化至-55 mV阈值，触发动作电位。"
    },
    {
      "index": 28,
      "timestamp": "00:12:25.520 - 00:12:49.920",
      "summary": "人工触发动作电位可研究不同神经元的发放频率和模式，例如调整刺激强度。"
    },
    {
      "index": 29,
      "timestamp": "00:12:51.840 - 00:13:19.840",
      "summary": "不同神经元对刺激的反应多样：有的初始高频后衰减，有的以固定频率规则发放，有的快速高频发放。"
    },
    {
      "index": 30,
      "timestamp": "00:13:20.880 - 00:14:00.240",
      "summary": "不同神经元基于其特性对刺激产生一系列不同响应，这些特性决定了具体的发放模式。"
    },
    {
      "index": 31,
      "timestamp": "00:14:00.240 - 00:14:05.920",
      "summary": "神经元的所有电特性都是可变的。"
    },
    {
      "index": 32,
      "timestamp": "00:14:08.240 - 00:14:26.240",
      "summary": "神经元活动可关联外部刺激，且这种关系在健康和疾病状态下会发生变化。"
    },
    {
      "index": 33,
      "timestamp": "00:14:27.760 - 00:15:01.520",
      "summary": "视觉系统中的神经元通过感受野对特定外部空间位置的刺激作出反应。"
    },
    {
      "index": 34,
      "timestamp": "00:15:02.400 - 00:15:26.160",
      "summary": "当光刺激呈现在感受野中心时，该类型神经元会增强其spiking activity。"
    },
    {
      "index": 35,
      "timestamp": "00:15:27.040 - 00:15:58.720",
      "summary": "光刺激出现在感受野外周则抑制其firing activity，也存在反应模式相反的细胞类型，且这些性质可变。"
    },
    {
      "index": 36,
      "timestamp": "00:15:59.440 - 00:16:31.520",
      "summary": "以听觉系统为例，健康神经元在低刺激下产生规则低频spike，高刺激下高频放电，而疾病状态下的放电模式不同。"
    },
    {
      "index": 37,
      "timestamp": "00:16:31.520 - 00:17:01.920",
      "summary": "在疾病状态下，相同刺激诱发的spike不规则，且最大放电频率低于正常状态。"
    },
    {
      "index": 38,
      "timestamp": "00:17:01.920 - 00:17:08.720",
      "summary": "疾病状态改变了神经元的功能，影响其行为。"
    },
    {
      "index": 39,
      "timestamp": "00:17:10.240 - 00:17:41.280",
      "summary": "神经系统具有可塑性，先前活动（如药物、经验、学习与记忆）可改变神经元特性。"
    },
    {
      "index": 40,
      "timestamp": "00:17:41.280 - 00:18:08.240",
      "summary": "首次接触某个项目后神经元特性发生微妙变化，导致再次接触时产生似曾相识或déjà vu体验。"
    },
    {
      "index": 41,
      "timestamp": "00:18:08.240 - 00:18:42.800",
      "summary": "介绍最简单的神经连接——前向兴奋，即神经元A的动作电位通过释放神经递质触发神经元B的动作电位。"
    },
    {
      "index": 42,
      "timestamp": "00:18:42.800 - 00:19:16.720",
      "summary": "加入抑制性神经元后，A兴奋B，B抑制C，使C沉默。"
    },
    {
      "index": 43,
      "timestamp": "00:19:18.400 - 00:19:39.920",
      "summary": "通过反馈机制，抑制性神经元B使C沉默A，形成自抑制循环。"
    },
    {
      "index": 44,
      "timestamp": "00:19:39.920 - 00:20:13.440",
      "summary": "正反馈循环中A触发B、B触发C，C又兴奋A，形成自维持的振荡，见于生物钟等周期性生理过程。"
    },
    {
      "index": 45,
      "timestamp": "00:20:13.440 - 00:20:49.680",
      "summary": "具有内在爆发特性（如泄漏通道）的神经元可组合成中枢模式发生器，产生自维持的模式。"
    },
    {
      "index": 46,
      "timestamp": "00:20:49.680 - 00:21:22.080",
      "summary": "记录spikes需要专业技能，且通常只能记录单个细胞的活动，无法获取网络全貌。"
    },
    {
      "index": 47,
      "timestamp": "00:21:23.280 - 00:21:38.000",
      "summary": "即使同时记录多个单细胞，仍无法获得神经活动的整体图景。"
    },
    {
      "index": 48,
      "timestamp": "00:21:39.120 - 00:22:12.080",
      "summary": "细胞及其网络具有可塑性，记录电极的干扰可能改变细胞性质，且细胞容易死亡。"
    },
    {
      "index": 49,
      "timestamp": "00:22:12.080 - 00:22:24.560",
      "summary": "电极刺入细胞膜会损伤细胞，不同细胞存活时间差异很大。"
    },
    {
      "index": 50,
      "timestamp": "00:22:25.120 - 00:22:56.640",
      "summary": "长时间记录可能影响数据真实性，且产生海量数据需要自动化处理。"
    },
    {
      "index": 51,
      "timestamp": "00:22:56.640 - 00:23:14.160",
      "summary": "神经元作为神经系统基本单元，其spike是输出信号，不同神经元特性可产生多样的spike patterns。"
    },
    {
      "index": 52,
      "timestamp": "00:23:15.280 - 00:23:46.880",
      "summary": "神经元特性可动态变化，且神经元间连接产生多种交互可能性；关键在于任何可想象的神经元网络机制或连接模式很可能真实存在。"
    },
    {
      "index": 53,
      "timestamp": "00:23:46.880 - 00:23:52.640",
      "summary": "若该机制尚未被实验证实，则等待研究者去发现。"
    }
  ]
}