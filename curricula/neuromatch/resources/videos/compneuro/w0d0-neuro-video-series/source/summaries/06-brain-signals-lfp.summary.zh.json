{
  "slug": "06-brain-signals-lfp",
  "title": "Brain Signals: LFP",
  "source_page": "https://compneuro.neuromatch.io/tutorials/W0D0_NeuroVideoSeries/student/W0D0_Tutorial6.html",
  "youtube_url": "https://youtube.com/watch?v=PwkYgrTE2fU",
  "summary_language": "zh",
  "summaries": [
    {
      "index": 1,
      "timestamp": "00:00:00.320 - 00:00:16.320",
      "summary": "本段介绍局部场电位（LFP）的定义，并指出有多种测量脑活动的方法。"
    },
    {
      "index": 2,
      "timestamp": "00:00:16.320 - 00:00:43.840",
      "summary": "神经元活动时产生的动作电位和突触输入可被电极记录，头皮电极记录的是EEG。"
    },
    {
      "index": 3,
      "timestamp": "00:00:44.560 - 00:01:11.840",
      "summary": "皮层表面电极记录ECoG，脑内电极可同时记录spikes和LFP，脑外还可记录MEG。"
    },
    {
      "index": 4,
      "timestamp": "00:01:13.520 - 00:01:17.760",
      "summary": "脑内胞外记录的典型分析是将信号分为高频和低频两个频带。"
    },
    {
      "index": 5,
      "timestamp": "00:01:19.680 - 00:01:40.720",
      "summary": "高频带（约几百Hz）称为多单元活动（MUA），测量电极附近单个神经元的spikes。"
    },
    {
      "index": 6,
      "timestamp": "00:01:43.360 - 00:02:04.640",
      "summary": "大多数神经生理学见解来自spikes分析，低频带即LFP具有更大功率。"
    },
    {
      "index": 7,
      "timestamp": "00:02:06.000 - 00:02:29.120",
      "summary": "传统上LFP常被忽略或不存储，因其测量群体神经元突触输入的亚阈值活动，难以解释。"
    },
    {
      "index": 8,
      "timestamp": "00:02:29.680 - 00:02:45.280",
      "summary": "不能直接从LFP波形判断某个波峰对应特定突触输入，需要更多先验分析才能解释为神经活动。"
    },
    {
      "index": 9,
      "timestamp": "00:02:47.120 - 00:03:00.640",
      "summary": "但我们已知神经元活动与胞外记录电位之间的关联。"
    },
    {
      "index": 10,
      "timestamp": "00:03:02.000 - 00:03:20.080",
      "summary": "该关联通过神经元的跨膜电流实现，通常模拟神经活动时关注胞体膜电位，因其决定是否产生动作电位。"
    },
    {
      "index": 11,
      "timestamp": "00:03:21.440 - 00:03:56.560",
      "summary": "通过模拟计算神经元的跨膜电流，可推算出脑内任意胞外位置的电位，最简单的模型是无限均匀容积导体。"
    },
    {
      "index": 12,
      "timestamp": "00:03:58.400 - 00:04:19.040",
      "summary": "在皮层内，胞外电导率可近似为各向同性的常数sigma，这种简化通常足够准确。"
    },
    {
      "index": 13,
      "timestamp": "00:04:19.600 - 00:05:02.560",
      "summary": "信号传播可用单一电导率sigma建模，也可推广到非均匀介质，如EEG电极必须穿过皮肤和头骨等不同组织。"
    },
    {
      "index": 14,
      "timestamp": "00:05:02.560 - 00:05:45.840",
      "summary": "跨膜电流与胞外电位（包括spike、LFP、EEG、ECoG）的关系明确，但LFP的解读比spike复杂，因为spike的胞外波形更标准化。"
    },
    {
      "index": 15,
      "timestamp": "00:05:50.400 - 00:06:02.240",
      "summary": "动作电位的胞内膜电位签名非常标准化，若电极位置固定，其胞外形状也相对固定。"
    },
    {
      "index": 16,
      "timestamp": "00:06:03.440 - 00:06:45.680",
      "summary": "LFP通常由突触输入产生，记录电位高度依赖突触位置；例如锥体神经元顶端树突上的兴奋性突触产生负向电流。"
    },
    {
      "index": 17,
      "timestamp": "00:06:45.680 - 00:06:51.600",
      "summary": "靠近兴奋性突触处的胞外电位呈负向，波形与突触电流形状接近。"
    },
    {
      "index": 18,
      "timestamp": "00:06:53.120 - 00:07:24.560",
      "summary": "远离突触或靠近胞体处电位极性相反，因为流入的电流必须从其他区域流出，这源于电缆方程的特性。"
    },
    {
      "index": 19,
      "timestamp": "00:07:27.760 - 00:07:59.280",
      "summary": "突触位置变化可完全改变LFP模式甚至使极性反转，多个突触输入可能产生相互抵消的效果。"
    },
    {
      "index": 20,
      "timestamp": "00:08:00.000 - 00:08:21.840",
      "summary": "即使强突触输入驱动神经元快速放电，若突触位置安排恰当，所产生的LFP可能很弱，如图所示。"
    },
    {
      "index": 21,
      "timestamp": "00:08:24.240 - 00:08:40.240",
      "summary": "展示了一个包含10,000个无内部连接的生物物理详细神经模型堆栈。"
    },
    {
      "index": 22,
      "timestamp": "00:08:40.240 - 00:08:45.920",
      "summary": "这些神经元没有内部连接，但接收来自外部的突触输入。"
    },
    {
      "index": 23,
      "timestamp": "00:08:48.400 - 00:09:23.760",
      "summary": "沿树突不同位置施加突触输入时，LFP波形极性反转，均匀分布则几乎无信号。"
    },
    {
      "index": 24,
      "timestamp": "00:09:25.280 - 00:10:00.000",
      "summary": "EEG测量径向排列的神经元群体时，信号需穿过脑脊液、头骨和头皮；切向排列会改变信号模式。"
    },
    {
      "index": 25,
      "timestamp": "00:10:01.600 - 00:10:15.280",
      "summary": "EEG和MEG的信号特性高度依赖神经元群体的方向。"
    },
    {
      "index": 26,
      "timestamp": "00:10:17.520 - 00:10:36.400",
      "summary": "使用简单的10,000神经元模型可以计算LFP、EEG和MEG等信号。"
    },
    {
      "index": 27,
      "timestamp": "00:10:38.080 - 00:10:48.480",
      "summary": "基于10,000神经元模型能够计算所有这些脑信号。"
    },
    {
      "index": 28,
      "timestamp": "00:10:50.240 - 00:11:04.240",
      "summary": "为此开发了LFPy工具，用于基于用户模型进行脑信号的正向建模。"
    },
    {
      "index": 29,
      "timestamp": "00:11:06.320 - 00:11:46.960",
      "summary": "Potjans & Diesmann模型是简化的皮层模型，含80,000个神经元，分四层，每层有兴奋性和抑制性群体，突触连接规则来自实验。"
    },
    {
      "index": 30,
      "timestamp": "00:11:47.840 - 00:12:28.560",
      "summary": "该模型使用integrate-and-fire点神经元，单区室无法产生胞外电位，但许多网络模型采用此类神经元。"
    },
    {
      "index": 31,
      "timestamp": "00:12:30.000 - 00:13:07.040",
      "summary": "通过两步法先模拟点神经元获得spike并存储，再结合多房室神经元计算LFP。"
    },
    {
      "index": 32,
      "timestamp": "00:13:07.040 - 00:13:20.480",
      "summary": "存储点神经元产生的spike后重新模拟，以同时计算LFP和EEG。"
    },
    {
      "index": 33,
      "timestamp": "00:13:23.840 - 00:13:56.480",
      "summary": "视觉皮层网络在900ms接收输入后出现活动波阵面，LFP和EEG同步记录到该活动。"
    },
    {
      "index": 34,
      "timestamp": "00:14:00.720 - 00:14:27.440",
      "summary": "将假设形式化为数学模型后计算其预测的测量结果，再与实验对比迭代。"
    },
    {
      "index": 35,
      "timestamp": "00:14:28.320 - 00:15:04.240",
      "summary": "传统网络模型仅通过spike与实验比较，但可同时记录的神经元数量有限。"
    },
    {
      "index": 36,
      "timestamp": "00:15:06.640 - 00:15:42.400",
      "summary": "spike记录受限于同时测量神经元数量（如Neuropixel约70-80个），各群体样本少且随机发放，信号不稳健。"
    },
    {
      "index": 37,
      "timestamp": "00:15:43.280 - 00:16:26.160",
      "summary": "LFP反映神经元群体活动，结合spike和LFP能更好约束模型，正与Allen研究所（Anton Arkhipov和Christof Koch团队）合作。"
    },
    {
      "index": 38,
      "timestamp": "00:16:26.160 - 00:17:06.480",
      "summary": "Allen研究所的模型包含25万个神经元模拟小鼠初级视觉皮层，并记录了多只小鼠的spike和LFP。"
    },
    {
      "index": 39,
      "timestamp": "00:17:07.040 - 00:17:47.520",
      "summary": "目标是构建能解释多种实验特征的多用途模型，因此不仅计算spike也计算LFP。"
    }
  ]
}